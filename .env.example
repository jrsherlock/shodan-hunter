# Shodan API key — single shared key used for every team query.
SHODAN_API_KEY=

# --- Azure OpenAI -----------------------------------------------------------
# Required for natural-language query generation.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# --- Team auth --------------------------------------------------------------
# HTTP basic auth in front of every page. Set a strong password.
# SH_AUTH_USERS is "user:password,user2:password2" — every teammate gets a
# distinct username so the audit log can attribute queries.
SH_AUTH_USERS=team:changeme

# --- Bind ------------------------------------------------------------------
# 0.0.0.0 lets others on your network reach it. Default 127.0.0.1.
SH_HOST=0.0.0.0
SH_PORT=8000

# --- State ----------------------------------------------------------------
# Where the SQLite DB lives. Holds the per-query audit log + result cache.
# SH_DB=./data/hunter.db

# --- Safety rails ----------------------------------------------------------
# Soft daily Shodan query-credit cap across the whole team. 0 disables.
SH_DAILY_BUDGET=200

# --- Honeypot detection (v0.3) ---------------------------------------------
# A 🍯 badge is shown on search rows / the host page when Shodan tags a host
# as a honeypot (free, tag-based via InternetDB + the banner).
# NOTE: Shodan RETIRED the per-IP honeyscore lab ("integrated into the regular
# crawlers"), so the two settings below now affect only a legacy numeric path
# that is rarely exercised. They are kept for compatibility.
SH_HONEYPOT_THRESHOLD=0.5
SH_HONEYSCORE_ROW_CAP=25

# --- Cache TTLs (v0.3) ----------------------------------------------------
# Seconds to cache domain recon results (Shodan passive DNS is slow-moving).
# Default 21600 (6 h).
SH_DOMAIN_CACHE_TTL=21600

# Seconds to cache the legacy honeyscore shim's (negative) results per IP.
# Default 86400 (24 h).
SH_HONEYSCORE_CACHE_TTL=86400

# Seconds to cache bulk DNS resolve/reverse results. Default 3600 (1 h).
SH_DNS_CACHE_TTL=3600

# Seconds to cache community query library results. Default 3600 (1 h).
SH_QUERIES_CACHE_TTL=3600

# --- Network alerts / monitoring (v0.3) ------------------------------------
# Enable the /alerts UI for registering IP-range monitors and triggers.
# Management actions cost no query credits but consume your plan's
# monitored-IP pool. Default true.
SH_ENABLE_ALERTS=true

# --- On-demand scanning (v0.3) — DANGER: reads scan credits ----------------
# Scanning uses SCAN credits (separate from query credits) and must only
# target IP ranges you are explicitly authorized to scan. Disabled by default.
# Set to true/1/yes to enable the /scan UI.
SH_ENABLE_SCAN=false

# Comma-separated CIDRs and/or IPs you are authorized to scan.
# When set, any scan request whose targets fall outside this list is rejected.
# When empty, the UI requires an explicit per-request "I am authorized"
# confirmation checkbox (the submission is logged either way).
# SH_SCAN_ALLOWLIST=10.0.0.0/8,192.168.1.0/24

# Hard ceiling on host count per scan submission, regardless of allowlist.
# Default 4096.
SH_SCAN_MAX_HOSTS=4096
